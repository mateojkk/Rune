# ===========================================
# RUNE MONOREPO ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and customize as needed

# ===========================================
# NETWORK SELECTION
# ===========================================
# Options: testnet | mainnet
NETWORK=testnet

# ===========================================
# API SERVER CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=3001

# ===========================================
# WALRUS CONFIGURATION
# ===========================================
# Default: testnet URLs are used when NETWORK=testnet
#          mainnet URLs are used when NETWORK=mainnet
# Override the following to use custom endpoints:
# WALRUS_PUBLISHER_URL=
# WALRUS_AGGREGATOR_URL=

# ===========================================
# SEAL CONFIGURATION
# ===========================================
# Default testnet package ID (works for both testnet and mainnet)
# Override only if using a custom deployment:
# SEAL_PACKAGE_ID=

# Optional: Override key server object IDs
# SEAL_KEY_SERVER_1=
# SEAL_KEY_SERVER_2=

# ===========================================
# WEB APP CONFIGURATION (apps/web/.env)
# ===========================================
# Copy to apps/web/.env if you need to override:
# VITE_API_BASE=http://localhost:3001