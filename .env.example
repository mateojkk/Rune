# ===========================================
# RUNE MONOREPO ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and customize as needed

# ===========================================
# NETWORK SELECTION
# ===========================================
# Options: testnet | mainnet
NETWORK=testnet

# ===========================================
# API SERVER CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=3001
VITE_API_BASE=http://localhost:3001

# ===========================================
# WEB APP CONFIGURATION
# ===========================================
VITE_WEB_URL=http://localhost:5173
VITE_REDIRECT_URL=http://localhost:5173/app/auth/callback

# ===========================================
# WALRUS CONFIGURATION
# ===========================================
# Default: testnet URLs are used when NETWORK=testnet
#          mainnet URLs are used when NETWORK=mainnet
# Override the following to use custom endpoints:
# WALRUS_PUBLISHER_URL=
# WALRUS_AGGREGATOR_URL=

# ===========================================
# SEAL CONFIGURATION
# ===========================================
# Default testnet package ID (works for both testnet and mainnet)
# Override only if using a custom deployment:
# SEAL_PACKAGE_ID=

# Optional: Override key server object IDs
# SEAL_KEY_SERVER_1=
# SEAL_KEY_SERVER_2=

# ===========================================
# ZKLOGIN CONFIGURATION (GOOGLE OAUTH)
# ===========================================
# Required for sign-in. Replace with your Google OAuth client ID.
# Authorized redirect URIs should include:
# - http://localhost:5173/app/auth/callback
# - https://your-domain.com/app/auth/callback
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
